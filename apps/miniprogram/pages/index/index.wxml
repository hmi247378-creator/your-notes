<view class="container">
  <!-- Header -->
  <view class="flex-between mb-32">
    <view>
      <view class="h1">你的笔记</view>
    </view>
    <view class="avatar shadow-sm"></view>
  </view>

  <!-- Input Card -->
  <view class="card">
    <view class="h2">快速录入</view>
    <view class="small mb-32">支持序号拆分与智能分类</view>

    <view class="flex-row gap-16 mb-32">
      <view class="label" style="font-size: 32rpx; margin-bottom: 0; flex-shrink: 0;">时间节点</view>
      <view class="flex-row gap-8" style="flex: 1;">
        <picker mode="date" value="{{dateVal}}" bindchange="onDateChange" style="flex: 1;">
          <view class="input" style="font-size: 28rpx; padding: 12rpx 20rpx;">📅 {{dateVal}}</view>
        </picker>
        <picker mode="time" value="{{timeVal}}" bindchange="onTimeChange" style="flex: 1;">
          <view class="input" style="font-size: 28rpx; padding: 12rpx 20rpx;">🕙 {{timeVal}}</view>
        </picker>
      </view>
    </view>

    <view class="mb-32">
      <view class="label" style="font-size: 36rpx;">记录内容</view>
      <textarea
        class="input"
        placeholder="在这里输入你的笔记内容..."
        value="{{text}}"
        bindinput="onInput"
        style="min-height: 400rpx; width: 100%; box-sizing: border-box; font-size: 34rpx;"
      />
    </view>

    <button 
      class="btn btn-primary" 
      bindtap="onSmartAdapt" 
      loading="{{saving}}" 
      disabled="{{saving || !text}}"
      style="color: #FFFFFF;"
    >智能标注</button>
  </view>


  <!-- Custom Floating Tab Bar -->
  <view class="tab-bar">
    <view class="tab-item tab-item-active" bindtap="goHome">
      <text class="tab-icon">✨</text>
      <text class="tab-label">创作</text>
    </view>
    <view class="tab-item" bindtap="goNotes">
      <text class="tab-icon">📖</text>
      <text class="tab-label">笔记</text>
    </view>
    <view class="tab-item" bindtap="goStats">
      <text class="tab-icon">📈</text>
      <text class="tab-label">统计</text>
    </view>
    <view class="tab-item" bindtap="goReminders">
      <text class="tab-icon">🔔</text>
      <text class="tab-label">提醒</text>
    </view>
  </view>
</view>

