.refresh-btn {
  width: 80rpx;
  height: 80rpx;
  background: white;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
}

.rotating {
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.highlight-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.stat-item {
  position: relative;
}

.progress-bg {
  height: 16rpx;
  background: #F1F5F9;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s cubic-bezier(0.1, 0.7, 1.0, 0.1);
}

.progress-fill.primary {
  background: linear-gradient(90deg, var(--primary), #A78BFA);
}

.progress-fill.secondary {
  background: linear-gradient(90deg, var(--secondary), #F472B6);
}

.pb-120 {
  padding-bottom: 200rpx;
}


