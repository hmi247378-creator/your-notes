.login-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 64rpx 48rpx;
}

.brand-hero {
  text-align: center;
  margin-top: 20rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-logo {
  width: 140rpx;
  height: 140rpx;
  background: white;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.api-config {
  background: transparent;
}

.api-card {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(10rpx);
}

.error-msg {
  color: #EF4444;
  text-align: center;
  background: #FEE2E2;
  padding: 24rpx;
  border-radius: 20rpx;
}


