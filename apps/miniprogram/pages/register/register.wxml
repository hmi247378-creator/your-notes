<view class="container login-container">
  <!-- Brand Header -->
  <view class="brand-hero">
    <view class="brand-logo shadow-md">✨</view>
    <view class="h1" style="margin-top: 32rpx; font-weight: 800; font-size: 56rpx;">加入你的笔记</view>
    <view class="body" style="color: var(--text-muted); margin-top: 8rpx;">开始您的智能记录之旅</view>
  </view>

  <view class="card shadow-md" style="margin-top: -20rpx;">
    <view class="h2 mb-32">注册</view>
    
    <view class="input-group">
      <text class="label" style="font-size: 28rpx;">昵称</text>
      <input class="input" style="height: 88rpx; font-size: 32rpx;" placeholder="选填 (2-20 个字符)" value="{{nickname}}" bindinput="onNickname" />
    </view>

    <view class="input-group mt-16">
      <text class="label" style="font-size: 28rpx;">邮箱</text>
      <input class="input" style="height: 88rpx; font-size: 32rpx;" placeholder="用于登录和找回" value="{{email}}" bindinput="onEmail" />
    </view>

    <view class="input-group mt-16">
      <text class="label" style="font-size: 28rpx;">密码</text>
      <input class="input" style="height: 88rpx; font-size: 32rpx;" password placeholder="至少 6 位字符" value="{{password}}" bindinput="onPassword" />
    </view>

    <button class="btn btn-primary mt-32" style="height: 88rpx; line-height: 88rpx; font-size: 32rpx;" bindtap="onRegister" loading="{{loading}}" disabled="{{loading || !email || !password}}">立即注册</button>
    
    <view class="text-center mt-32">
      <text class="small" style="color: var(--text-muted);">已有账号？</text>
      <text class="small" style="color: var(--primary); font-weight: 600; margin-left: 8rpx;" bindtap="toLogin">去登录</text>
    </view>
  </view>

  <view wx:if="{{error}}" class="error-msg small mt-32">{{error}}</view>
</view>
