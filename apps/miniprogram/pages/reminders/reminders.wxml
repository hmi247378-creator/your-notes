<view class="container pb-120">
  <!-- Header -->
  <view class="flex-between mb-32">
    <view>
      <view class="h1">提醒事项</view>
      <view class="small">了解待处理与已完成项</view>
    </view>
    <view class="refresh-btn {{loading ? 'rotating' : ''}}" bindtap="refresh">
      <text>🔄</text>
    </view>
  </view>

  <!-- Search Area -->
  <view class="card mb-32">
    <view class="flex-row gap-16">
      <view class="search-bar" style="flex: 1;">
        <icon type="search" size="18" color="#94A3B8" />
        <input 
          class="body" 
          placeholder="搜索内容..." 
          value="{{q}}" 
          bindinput="onSearchInput" 
          bindconfirm="onSearchConfirm"
        />
      </view>
      <picker mode="selector" range="{{statusOptions}}" value="{{statusIndex}}" bindchange="onStatusChange">
        <view class="filter-btn active">
          <text>⚡</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- Loading State -->
  <view wx:if="{{loading}}" class="card empty-state">
    <view class="body text-muted">加载中…</view>
  </view>

  <!-- Reminders List -->
  <view wx:else class="reminders-list">
    <block wx:for="{{items}}" wx:key="id">
      <view class="card shadow-sm mb-32">
        <view class="flex-between mb-16">
          <view class="small">{{item.recordDate}} · {{item.status}}</view>
          <view wx:if="{{item.remindDate}}" class="badge badge-purple">
            {{item.remindDate}} {{item.remindTime}}
          </view>
        </view>
        <view class="body mb-32" style="font-weight: 600;">{{item.content}}</view>
        <view class="flex-row gap-16">
          <button class="btn btn-secondary" style="flex: 1;" data-note-id="{{item.noteId}}" bindtap="onOpenNote">查看笔记</button>
          <button class="btn btn-primary" style="flex: 1;" data-id="{{item.id}}" bindtap="onMarkDone">标记完成</button>
        </view>
      </view>
    </block>
    
    <view wx:if="{{items.length === 0}}" class="empty-state">
      <text class="empty-icon">🔔</text>
      <view class="body text-muted">目前没有提醒事项</view>
    </view>
  </view>

  <!-- Bottom Nav -->
  <view class="tab-bar">
    <view class="tab-item" bindtap="goHome">
      <text class="tab-icon">✨</text>
      <text class="tab-label">创作</text>
    </view>
    <view class="tab-item" bindtap="goNotes">
      <text class="tab-icon">📖</text>
      <text class="tab-label">笔记</text>
    </view>
    <view class="tab-item" bindtap="goStats">
      <text class="tab-icon">📈</text>
      <text class="tab-label">统计</text>
    </view>
    <view class="tab-item tab-item-active">
      <text class="tab-icon">🔔</text>
      <text class="tab-label">提醒</text>
    </view>
  </view>
</view>

