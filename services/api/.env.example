# 默认使用 SQLite（无需 Docker）
DATABASE_URL="file:./dev.db"

# 若你要切回 Postgres：
# 1) 把 prisma/schema.prisma 的 provider 改为 "postgresql"
# 2) 使用下面示例（或你的本机 Postgres 配置）
# DATABASE_URL="postgresql://yournotes:yournotes@localhost:5432/yournotes?schema=public"
JWT_SECRET="change-me"
PORT=3001

# 可选：LLM 语义分类（提升“适配”准确率）
# 配后启用“规则优先 + LLM 兜底”混合模式 + 智能语义分段

# --- OpenAI（默认）---
# OPENAI_API_KEY="sk-xxx"

# --- DeepSeek ---
# OPENAI_API_KEY="sk-你的DeepSeek密钥"
# OPENAI_BASE_URL="https://api.deepseek.com"
# LLM_MODEL="deepseek-chat"

